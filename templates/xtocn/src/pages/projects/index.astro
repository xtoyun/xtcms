---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getContent } from '../../core/content';
const projects = getContent('projects', 'src/content/projects');
---
<BaseLayout title="项目案例">
  <section style="padding:60px 0">
    <div class="container">
      <h1 style="font-size:34px;font-weight:400;color:#000;margin-bottom:0.3em">项目<span style="font-weight:300">案例</span></h1>
      <p style="font-size:16px;color:var(--xt-muted);margin-bottom:40px">共 {projects.length} 个项目</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:30px">
        {projects.map(p => (
          <a href={`/projects/${p.slug}`} style="text-decoration:none;color:inherit;display:block">
            <div style="aspect-ratio:16/10;background:#f5f5f5;overflow:hidden;margin-bottom:16px">
              {p.data.image ? <img src={p.data.image} alt={p.data.title} style="width:100%;height:100%;object-fit:cover" /> : <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#ccc;font-size:48px">📁</div>}
            </div>
            <span style="font-size:13px;color:#fff;background:#000;padding:2px 10px;border-radius:2px">{p.data.category}</span>
            <h3 style="font-size:18px;font-weight:500;color:#000;margin-top:12px">{p.data.title}</h3>
            <p style="font-size:14px;color:var(--xt-muted);margin-top:6px;line-height:1.6">{p.data.description}</p>
          </a>
        ))}
      </div>
      {projects.length === 0 && <p style="text-align:center;color:var(--xt-muted);padding:60px">项目案例即将更新</p>}
    </div>
  </section>
</BaseLayout>
