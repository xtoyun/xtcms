---
import BaseLayout from '$layouts/BaseLayout.astro';
import { getContent } from '$core/content';
const products = getContent('products', 'src/content/products');
---
<BaseLayout title="产品中心">
  <section style="padding:60px 0">
    <div class="container">
      <h1 style="font-size:34px;font-weight:400;color:#000;margin-bottom:0.3em">产品<span style="font-weight:300">中心</span></h1>
      <p style="font-size:16px;color:var(--xt-muted);margin-bottom:40px">共 {products.length} 款产品</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:24px">
        {products.map(p => (
          <a href={`/products/${p.slug}`} style="text-decoration:none;color:inherit;display:block;border:1px solid #eee;overflow:hidden;transition:box-shadow 0.3s">
            <div style="aspect-ratio:1/1;background:#f5f5f5;overflow:hidden">
              {p.data.image ? <img src={p.data.image} alt={p.data.title} style="width:100%;height:100%;object-fit:cover" /> : <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#ccc;font-size:48px">📦</div>}
            </div>
            <div style="padding:24px">
              <span style="font-size:12px;color:var(--xt-muted);background:#f5f5f5;padding:2px 8px;border-radius:2px">{p.data.category}</span>
              <h3 style="font-size:18px;font-weight:500;color:#000;margin-top:10px">{p.data.title}</h3>
              <p style="font-size:14px;color:var(--xt-muted);margin-top:6px;line-height:1.6">{p.data.description}</p>
              {p.data.price && <p style="font-size:20px;font-weight:600;color:var(--xt-accent);margin-top:12px">{p.data.price}</p>}
            </div>
          </a>
        ))}
      </div>
      {products.length === 0 && <p style="text-align:center;color:var(--xt-muted);padding:60px">产品即将上线</p>}
    </div>
  </section>
</BaseLayout>
