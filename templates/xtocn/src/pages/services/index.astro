---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getContent } from '../../core/content';
const services = getContent('services', 'src/content/services')
  .sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
---
<BaseLayout title="服务项目">
  <section style="padding:60px 0">
    <div class="container">
      <h1 style="font-size:34px;font-weight:400;color:#000;margin-bottom:0.3em">服务<span style="font-weight:300">项目</span></h1>
      <p style="font-size:16px;color:var(--xt-muted);margin-bottom:50px">六大核心服务，覆盖网络营销全链路</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:30px">
        {services.map(s => (
          <a href={`/services/${s.slug}`} style="text-decoration:none;color:inherit;display:block;border:1px solid #eee;padding:40px 30px;transition:border-color 0.3s,box-shadow 0.3s">
            {s.data.image && <div style="aspect-ratio:16/10;background:#f5f5f5;overflow:hidden;margin-bottom:20px"><img src={s.data.image} alt={s.data.title} style="width:100%;height:100%;object-fit:cover" /></div>}
            <h3 style="font-size:22px;font-weight:400;color:#000;margin-bottom:12px">{s.data.title}</h3>
            <p style="font-size:15px;color:var(--xt-muted);line-height:1.8;margin-bottom:20px">{s.data.description}</p>
            <span style="font-size:13px;color:#999;display:flex;align-items:center;gap:4px">详细了解 <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
          </a>
        ))}
      </div>
      {services.length === 0 && <p style="text-align:center;color:var(--xt-muted);padding:80px">服务项目即将更新</p>}
    </div>
  </section>
</BaseLayout>
