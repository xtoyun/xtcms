---
import BaseLayout from '$layouts/BaseLayout.astro';
import { getContent } from '$core/content';
const projects = getContent('opensource', 'src/content/opensource');
---
<BaseLayout title="开源项目">
  <section style="padding:60px 0">
    <div class="container">
      <h1 style="font-size:34px;font-weight:400;color:#000;margin-bottom:0.3em">开源<span style="font-weight:300">项目</span></h1>
      <p style="font-size:16px;color:var(--xt-muted);margin-bottom:40px">Apache-2.0 许可 · 社区驱动 · 自由开放</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:24px">
        {projects.map(p => (
          <a href={p.data.link || `/open/${p.slug}`} target={p.data.link ? '_blank' : '_self'} rel={p.data.link ? 'noopener' : ''} style="text-decoration:none;color:inherit;display:block;border:1px solid #eee;overflow:hidden;transition:box-shadow 0.3s">
            <div style="aspect-ratio:360/250;background:#f5f5f5;overflow:hidden">
              {p.data.image ? <img src={p.data.image} alt={p.data.title} style="width:100%;height:100%;object-fit:cover" /> : <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#ccc;font-size:48px">📦</div>}
            </div>
            <div style="padding:24px">
              <div style="display:flex;align-items:baseline;gap:8px;margin-bottom:8px">
                <h3 style="font-size:18px;font-weight:500;color:#000">{p.data.title}</h3>
                <span style="font-size:11px;color:#999">{p.data.tag}</span>
              </div>
              <p style="font-size:13px;color:#888;line-height:1.7">{p.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
