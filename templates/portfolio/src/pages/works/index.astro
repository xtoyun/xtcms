---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getContent } from '../../core/content';
const works = getContent('works', 'src/content/works');
---
<BaseLayout title="Works">
  <section style="padding: 80px 0; max-width: 1200px; margin: 0 auto; padding-left: 40px; padding-right: 40px;">
    <h1 style="font-size: 12px; font-weight: 600; color: var(--xt-muted); text-transform: uppercase; letter-spacing: 2px; margin-bottom: 40px;">
      All Work · {works.length} projects
    </h1>
    {works.length > 0 ? (
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 20px;">
        {works.map(w => (
          <a href={`/works/${w.slug}`} style="text-decoration: none; color: inherit; display: block; position: relative; overflow: hidden; border-radius: 2px;">
            <div style="aspect-ratio: 4/3; background: #e8e8e8; overflow: hidden;">
              {w.data.image ? (
                <img src={w.data.image} alt={w.data.title} style="width: 100%; height: 100%; object-fit: cover;" />
              ) : (
                <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #ccc; font-size: 48px;">?</div>
              )}
            </div>
            <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 24px; background: linear-gradient(transparent, rgba(0,0,0,0.7)); color: #fff;">
              <span style="font-size: 11px; opacity: 0.7; text-transform: uppercase; letter-spacing: 1px;">{w.data.category}</span>
              <h3 style="font-size: 18px; font-weight: 500; margin-top: 4px;">{w.data.title}</h3>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p style="text-align: center; color: var(--xt-muted); padding: 60px;">No works yet.</p>
    )}
  </section>
</BaseLayout>
