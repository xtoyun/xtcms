---
import '../styles/global.css';

export interface Props { title?: string; description?: string; }

const { title, description } = Astro.props;
const siteTitle = title ? `${title} - 雄韬官网` : '雄韬官网 - 网络营销品牌';
const navItems = [
  { label: '首页', href: '/' },
  { label: '项目', href: '/projects' },
  { label: '服务', href: '/services' },
  { label: '文章', href: '/posts' },
  { label: '关于', href: '/about' },
  { label: '联系', href: '/contact' },
];
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{siteTitle}</title>
  <meta name="description" content={description || '15年互联网营销品牌，为数百家公司提供网络营销咨询服务'} />
  <link rel="icon" type="image/png" href="/favicon.png" />
</head>

<body class="min-h-screen flex">

  <!-- Left Sidebar - matching The7 theme vertical header -->
  <aside class="fixed left-0 top-0 h-full bg-white flex flex-col z-50" style="width:300px;padding:50px 40px">
    <!-- Logo -->
    <a href="/" class="no-underline mb-16 block">
      <img src="/logo.png" alt="雄韬网络" style="width:80px;height:auto;display:block" />
    </a>

    <!-- Nav -->
    <nav class="flex-1">
      <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:24px">
        {navItems.map(item => (
          <li>
            <a href={item.href}
              class="font-normal text-black no-underline hover:opacity-70 transition-opacity block"
              style="font-size:18px;font-weight:400;line-height:1.4"
            >{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Contact info at bottom -->
    <div class="mt-auto pt-10" style="border-top:1px solid #eee">
      <div style="display:flex;flex-direction:column;gap:10px;font-size:15px;color:#7C7F83;padding-top:20px">
        <div class="flex items-center gap-3">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          <a href="mailto:xc@xtocn.com" style="color:#7C7F83;text-decoration:none">xc@xtocn.com</a>
        </div>
        <div class="flex items-center gap-3">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span>020-28186541</span>
        </div>
      </div>
    </div>
  </aside>

  <!-- Mobile hamburger (only shown on small screens) -->
  <button id="mobile-toggle" class="hidden max-md:flex fixed top-4 left-4 z-50 p-2 bg-white border border-gray-200 rounded" aria-label="菜单">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
  </button>

  <!-- Mobile menu overlay -->
  <div id="mobile-menu" class="hidden fixed inset-0 z-40 bg-white p-8 flex flex-col gap-4 overflow-auto">
    <button id="mobile-close" class="self-end p-2 text-2xl">&times;</button>
    <a href="/" class="text-lg font-bold text-black no-underline">雄韬官网</a>
    <nav class="flex flex-col gap-3">
      {navItems.map(item => (
        <a href={item.href} class="text-base text-black no-underline py-2 border-b border-gray-100">{item.label}</a>
      ))}
    </nav>
    <div class="mt-4 pt-4 border-t border-gray-200 text-sm" style="color:#7C7F83">
      <p>📧 xc@xtocn.com</p>
      <p>📞 020-28186541</p>
    </div>
  </div>

  <!-- Main content area -->
  <div class="flex-1 flex flex-col min-h-screen" style="margin-left:300px">
    <main class="flex-1"><slot /></main>

    <!-- Footer - matching original: white bg, gray text -->
    <footer style="background:#fff;color:#999;padding:40px 0 30px;border-top:1px solid #eee">
      <div style="max-width:1200px;margin:0 auto;padding:0 40px">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:30px;margin-bottom:20px">
          <div style="font-size:13px;line-height:2">
            <p style="margin:0;color:#999">&copy; {new Date().getFullYear()} 雄韬官网. All rights reserved.</p>
            <p style="margin:0">
              <a href="https://beian.miit.gov.cn/" target="_blank" rel="nofollow" style="color:#999;text-decoration:none">粤ICP备14002355号</a>
            </p>
            <p style="margin:0">
              <a href="https://beian.mps.gov.cn/" target="_blank" rel="nofollow" style="color:#999;text-decoration:none">粤公网安备44011302004411号</a>
            </p>
          </div>
          <div style="font-size:13px;line-height:2;text-align:right">
            <p style="margin:0;color:#999">📧 xc@xtocn.com</p>
            <p style="margin:0;color:#999">📞 020-28186541</p>
          </div>
        </div>
        <div style="text-align:center">
          <a href="#" onclick="window.scrollTo({top:0,behavior:'smooth'});return false" style="color:#999;text-decoration:none;font-size:13px">↑ 返回顶部</a>
        </div>
      </div>
    </footer>
  </div>

  <script is:inline>
    (function(){
      const toggle = document.getElementById('mobile-toggle');
      const menu = document.getElementById('mobile-menu');
      const close = document.getElementById('mobile-close');
      if(toggle&&menu){toggle.onclick=()=>menu.classList.remove('hidden');}
      if(close&&menu){close.onclick=()=>menu.classList.add('hidden');}
      // Show mobile toggle on small screens
      if(window.innerWidth<768){toggle&&toggle.classList.remove('hidden');}
    })();
  </script>
</body>
</html>
