---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getContent } from '../core/content';
import { marked } from 'marked';

const { slug } = Astro.params;
const pageSlug = slug || 'index';

// Skip known collection routes — let dedicated pages handle them
const knownRoutes = ['docs', 'projects', 'services', 'products', 'posts', 'contact', 'admin', 'api', 'open', 'works'];
if (knownRoutes.includes(pageSlug)) {
  return Astro.redirect('/404');
}

// Look up the page from the pages collection
const pages = getContent('pages', 'src/content/pages');
const page = pages.find(p => p.slug === pageSlug);

if (!page) {
  return Astro.redirect('/404');
}

const htmlContent = page.body ? marked.parse(page.body) : '';
---

<BaseLayout title={page.data.title}>
  <article style="padding: 60px 0;">
    <div style="max-width: var(--xt-container-width, 800px); margin: 0 auto; padding: 0 40px;">
      <header style="margin-bottom: 50px;">
        <h1 style="font-size: 34px; font-weight: 400; color: var(--xt-primary); line-height: 1.3;">
          {page.data.title}
        </h1>
      </header>

      {htmlContent ? (
        <div class="cms-content" style="font-size: var(--xt-body-size); line-height: 1.9; color: var(--xt-text);"
          set:html={htmlContent} />
      ) : (
        <div style="text-align: center; padding: 40px 0; color: var(--xt-muted);">
          暂无内容
        </div>
      )}
    </div>
  </article>
</BaseLayout>

<style is:inline>
  .cms-content h2 { font-size: 24px; font-weight: 400; color: var(--xt-primary); margin-top: 1.5em; margin-bottom: 0.5em; }
  .cms-content h3 { font-size: 20px; font-weight: 400; color: var(--xt-primary); margin-top: 1.2em; margin-bottom: 0.5em; }
  .cms-content p { margin-bottom: 1em; }
  .cms-content img { max-width: 100%; border-radius: 4px; }
  .cms-content pre { background: #f5f5f5; padding: 16px; border-radius: 4px; overflow-x: auto; font-size: 14px; }
  .cms-content code { background: #f5f5f5; padding: 2px 6px; border-radius: 2px; font-size: 0.9em; }
  .cms-content blockquote { border-left: 3px solid var(--xt-primary); padding-left: 16px; margin-left: 0; color: var(--xt-muted); }
  .cms-content ul, .cms-content ol { padding-left: 1.5em; margin-bottom: 1em; }
</style>
