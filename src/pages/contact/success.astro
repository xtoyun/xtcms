---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="提交成功">
  <section style="padding:100px 0;text-align:center">
    <div style="max-width:500px;margin:0 auto;padding:0 40px">
      <div style="font-size:48px;margin-bottom:20px">✅</div>
      <h1 style="font-size:34px;font-weight:400;color:#000;margin-bottom:16px">提交成功</h1>
      <p style="font-size:16px;color:#7C7F83;margin-bottom:30px">感谢您的留言，我们会尽快与您联系。</p>
      <a href="/" class="btn-the7">返回首页</a>
    </div>
  </section>
</BaseLayout>
