---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getContent } from '../../lib/content';
import { autoLinkKeywords } from '../../lib/auto-link';
import { marked } from 'marked';

const { slug } = Astro.params;
const posts = getContent('src/content/posts');
const post = posts.find(p => p.id === slug);

if (!post) {
  return Astro.redirect('/posts');
}

// If post has an external link, redirect
if (post.data.link) {
  return Astro.redirect(post.data.link);
}

const htmlContent = post.body ? autoLinkKeywords(marked.parse(post.body) as string) : '';
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article style="padding:80px 0">
    <div style="max-width:750px;margin:0 auto;padding:0 40px">
      <a href="/posts" style="font-size:14px;color:#7C7F83;text-decoration:none">← 返回文章列表</a>

      <header style="margin-top:40px;margin-bottom:50px">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px">
          <time style="font-size:13px;color:#aaa">{post.data.date ? new Date(post.data.date).toLocaleDateString('zh-CN') : ''}</time>
          {Array.isArray(post.data.tags) && post.data.tags.map((tag: string) => (
            <span style="font-size:12px;color:#7C7F83;background:#f5f5f5;padding:2px 8px;border-radius:2px">{tag}</span>
          ))}
        </div>
        <h1 style="font-size:34px;font-weight:400;color:#000;line-height:1.3;margin:0 0 16px 0">{post.data.title}</h1>
        {post.data.description && (
          <p style="font-size:18px;color:#7C7F83;line-height:1.7;margin:0">{post.data.description}</p>
        )}
      </header>

      <div class="cms-content" style="font-size:16px;line-height:1.9;color:#333" set:html={htmlContent} />

      <footer style="margin-top:60px;padding-top:30px;border-top:1px solid #eee">
        <a href="/posts" style="font-size:14px;color:#7C7F83;text-decoration:none">← 返回文章列表</a>
      </footer>
    </div>
  </article>
</BaseLayout>
