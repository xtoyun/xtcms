---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SafeImage from '../../components/shared/SafeImage.astro';
import { getContent } from '../../lib/content';

const posts = getContent('src/content/posts')
  .filter(p => !p.data.draft);
---

<BaseLayout title="文章">
  <section style="padding:80px 0">
    <div style="max-width:1200px;margin:0 auto;padding:0 40px">
      <h1 style="font-size:34px;font-weight:400;color:#000;margin-bottom:0.3em">文章</h1>
      <p style="font-size:16px;color:#7C7F83;margin-bottom:50px">互联网营销 · 品牌建设 · 数字化转型</p>

      {
        posts.length > 0 ? (
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(350px,1fr));gap:30px">
            {posts.map(post => (
              <a href={post.data.link || `/posts/${post.id}`} style="text-decoration:none;color:inherit;display:block">
                <article style="border:1px solid #eee;transition:border-color 0.3s;overflow:hidden">
                  <SafeImage src={post.data.image} alt={post.data.title} aspect="16/9" />
                  <div style="padding:30px">
                    <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px">
                      {post.data.pinned && <span style="font-size:11px;color:#d4380d;background:#fff2e8;border:1px solid #ffbb96;padding:1px 8px;border-radius:2px;font-weight:500">置顶</span>}
                      <time style="font-size:12px;color:#aaa">{post.data.date ? new Date(post.data.date).toLocaleDateString('zh-CN') : ''}</time>
                      {post.data.tags && Array.isArray(post.data.tags) && post.data.tags.length > 0 && (
                        <span style="font-size:11px;color:#7C7F83;background:#f5f5f5;padding:2px 8px;border-radius:2px">{post.data.tags[0]}</span>
                      )}
                    </div>
                    <h2 style="font-size:20px;font-weight:400;color:#000;line-height:1.4;margin:0 0 10px 0;display:flex;align-items:center;gap:8px">
                      {post.data.title}
                      {post.data.link && <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#aaa" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>}
                    </h2>
                    {post.data.description && (
                      <p style="font-size:14px;color:#7C7F83;line-height:1.7;margin:0">{post.data.description}</p>
                    )}
                  </div>
                </article>
              </a>
            ))}
          </div>
        ) : (
          <div style="text-align:center;padding:80px 0;color:#7C7F83">精彩内容即将上线</div>
        )
      }
    </div>
  </section>
</BaseLayout>
