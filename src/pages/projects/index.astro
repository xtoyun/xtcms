---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SafeImage from '../../components/shared/SafeImage.astro';
import { getContent } from '../../lib/content';

const allProjects = getContent('src/content/projects');

const categories = [...new Set(allProjects.map(p => p.data.category))];
---

<BaseLayout title="项目案例">
  <section style="padding:80px 0">
    <div style="max-width:1200px;margin:0 auto;padding:0 40px">
      <h1 style="font-size:34px;font-weight:400;color:#000;margin-bottom:0.3em">项目<span style="font-weight:300">案例</span></h1>
      <p style="font-size:16px;color:#7C7F83;margin-bottom:50px">我们的项目作品展示</p>

      {
        allProjects.length === 0 ? (
          <div style="text-align:center;padding:80px 0;color:#7C7F83">暂无项目案例</div>
        ) : (
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(350px,1fr));gap:30px">
            {allProjects.map(project => (
              <a href={`/projects/${project.id}`} style="text-decoration:none;color:inherit;display:block">
                <!-- Image -->
                <div style="aspect-ratio:4/3;background:#f5f5f5;overflow:hidden;margin-bottom:20px">
                  <SafeImage src={project.data.image} alt={project.data.title} aspect="4/3" thumb />
                </div>
                <!-- Info -->
                <div style="display:flex;gap:8px;align-items:center;margin-bottom:8px">
                  {project.data.pinned && <span style="font-size:11px;color:#d4380d;background:#fff2e8;border:1px solid #ffbb96;padding:1px 8px;border-radius:2px;font-weight:500">置顶</span>}
                  <span style="font-size:11px;color:#fff;background:#000;padding:2px 8px;border-radius:2px">{project.data.category}</span>
                  {project.data.date && <span style="font-size:12px;color:#aaa">{String(project.data.date).slice(0,10)}</span>}
                </div>
                <h3 style="font-size:18px;font-weight:400;color:#000;margin:0 0 8px 0;line-height:1.4">{project.data.title}</h3>
                <p style="font-size:14px;color:#7C7F83;margin:0;line-height:1.6">{project.data.description}</p>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
