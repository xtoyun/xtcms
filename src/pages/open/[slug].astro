---
import BaseLayout from '$layouts/BaseLayout.astro';
import { getContent } from '$core/content';
import { marked } from 'marked';

const { slug } = Astro.params;
const projects = getContent('opensource', 'src/content/opensource');
const project = projects.find(p => p.slug === slug);
if (!project) return Astro.redirect('/open');

// If project has external link, redirect
if (project.data.link) {
  return Astro.redirect(project.data.link);
}

const htmlBody = project.body ? marked.parse(project.body) : '';
---
<BaseLayout title={project.data.title}>
  <section style="padding:60px 0">
    <div class="container" style="max-width:800px">
      <a href="/open" style="font-size:14px;color:var(--xt-muted)">← 返回开源项目</a>
      <div style="margin-top:40px">
        {project.data.image && <img src={project.data.image} alt={project.data.title} style="width:100%;max-height:400px;object-fit:cover;margin-bottom:30px" />}
        <div style="display:flex;gap:12px;align-items:center;margin-bottom:20px">
          <span style="font-size:13px;color:var(--xt-muted);background:#f5f5f5;padding:2px 10px;border-radius:2px">{project.data.tag}</span>
        </div>
        <h1 style="font-size:34px;font-weight:400;color:#000;margin-bottom:20px">{project.data.title}</h1>
        <p style="font-size:18px;font-weight:300;color:var(--xt-muted);line-height:1.8;margin-bottom:40px">{project.data.description}</p>
        {htmlBody && <div class="cms-content" set:html={htmlBody} />}
      </div>
    </div>
  </section>
</BaseLayout>
<style is:inline>
  .cms-content h2 { font-size:24px;font-weight:400;margin-top:1.5em;margin-bottom:0.5em;color:#000; }
  .cms-content p { margin-bottom:1em;line-height:1.9; }
</style>
