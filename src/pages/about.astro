---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getContent } from '../lib/content';
import { marked } from 'marked';

const pages = getContent('src/content/pages');
const aboutPage = pages.find(p => p.id === 'about');
const htmlContent = aboutPage?.body ? marked.parse(aboutPage.body) : '';
const title = aboutPage?.data.title || '关于雄韬网络';
---

<BaseLayout title={title}>
  <section style="padding:80px 0">
    <div style="max-width:750px;margin:0 auto;padding:0 40px">
      <h1 style="font-size:34px;font-weight:400;color:#000;margin-bottom:40px">{title}</h1>

      <div class="cms-content" style="font-size:18px;font-weight:300;color:#7C7F83;line-height:1.8" set:html={htmlContent} />

      <div style="margin-top:60px;padding:30px;border:1px solid #eee">
        <h3 style="font-size:22px;font-weight:400;color:#000;margin-bottom:16px">联系我们</h3>
        <div style="font-size:15px;color:#7C7F83;line-height:2">
          <p style="margin:0">📧 邮箱：xc@xtocn.com</p>
          <p style="margin:0">📞 电话：020-28186541</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
