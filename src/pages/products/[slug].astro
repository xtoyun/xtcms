---
import BaseLayout from '$layouts/BaseLayout.astro';
import { getContent } from '$core/content';
import { marked } from 'marked';

const { slug } = Astro.params;
const products = getContent('products', 'src/content/products');
const product = products.find(p => p.slug === slug);
if (!product) return Astro.redirect('/products');
const htmlBody = product.body ? marked.parse(product.body) : '';
---
<BaseLayout title={product.data.title}>
  <section style="padding:60px 0">
    <div class="container" style="max-width:900px">
      <a href="/products" style="font-size:14px;color:var(--xt-muted)">← 返回产品中心</a>
      <div style="margin-top:40px">
        {product.data.image && <img src={product.data.image} alt={product.data.title} style="width:100%;max-height:500px;object-fit:cover;margin-bottom:30px" />}
        <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;margin-bottom:20px">
          <span style="font-size:13px;color:#fff;background:#000;padding:2px 10px;border-radius:2px">{product.data.category}</span>
          {product.data.date && <span style="font-size:13px;color:var(--xt-muted)">{String(product.data.date).slice(0,10)}</span>}
        </div>
        <h1 style="font-size:34px;font-weight:400;color:#000;margin-bottom:20px">{product.data.title}</h1>
        {product.data.price && <p style="font-size:24px;font-weight:600;color:var(--xt-accent);margin-bottom:20px">{product.data.price}</p>}
        <p style="font-size:18px;font-weight:300;color:var(--xt-muted);line-height:1.8;margin-bottom:40px">{product.data.description}</p>
        {htmlBody && <div class="cms-content" set:html={htmlBody} />}
      </div>
    </div>
  </section>
</BaseLayout>
<style is:inline>
  .cms-content h2 { font-size:24px;font-weight:400;margin-top:1.5em;margin-bottom:0.5em;color:#000; }
  .cms-content p { margin-bottom:1em;line-height:1.9; }
  .cms-content img { max-width:100%;border-radius:4px; }
</style>
