---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="联系我们">
  <section class="py-20">
    <div class="container-main max-w-2xl">
      <h1 class="text-center mb-4">联系<span style="font-weight:300">我们</span></h1>
      <p style="color:#7C7F83;text-align:center;margin-bottom:3rem">请告诉您的需求！我们为你提供更好的服务</p>
      <form class="space-y-6" method="POST" action="/api/contact">
        <div>
          <label class="block text-sm mb-2" style="color:#000">您的姓名 *</label>
          <input type="text" name="name" required class="w-full px-4 py-3 border border-gray-300 bg-white text-black focus:border-black focus:outline-none" placeholder="请输入姓名" />
        </div>
        <div>
          <label class="block text-sm mb-2" style="color:#000">公司名称</label>
          <input type="text" name="company" class="w-full px-4 py-3 border border-gray-300 bg-white text-black focus:border-black focus:outline-none" placeholder="请输入公司名称" />
        </div>
        <div>
          <label class="block text-sm mb-2" style="color:#000">联系电话 *</label>
          <input type="tel" name="phone" required class="w-full px-4 py-3 border border-gray-300 bg-white text-black focus:border-black focus:outline-none" placeholder="请输入电话" />
        </div>
        <div>
          <label class="block text-sm mb-2" style="color:#000">邮箱</label>
          <input type="email" name="email" class="w-full px-4 py-3 border border-gray-300 bg-white text-black focus:border-black focus:outline-none" placeholder="请输入邮箱" />
        </div>
        <div>
          <label class="block text-sm mb-2" style="color:#000">您的需求 *</label>
          <textarea name="message" required rows="5" class="w-full px-4 py-3 border border-gray-300 bg-white text-black focus:border-black focus:outline-none resize-none" placeholder="请描述您的项目需求..."></textarea>
        </div>
        <button type="submit" class="btn-the7 btn-the7-lg w-full">提交需求</button>
      </form>
    </div>
  </section>
</BaseLayout>
