---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="联系我们">
  <section class="py-20">
    <div class="container-main max-w-2xl">
      <h1 class="text-4xl font-bold text-white mb-4 text-center"><span class="text-brand-gold">联系</span>我们</h1>
      <p class="text-gray-400 text-center mb-12">请告诉您的需求！我们为你提供更好的服务</p>

      <form class="space-y-6" method="POST" action="/contact/success">
        <div>
          <label class="block text-sm text-gray-400 mb-2">您的姓名 *</label>
          <input type="text" name="name" required class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder-gray-600 focus:border-brand-gold focus:outline-none" placeholder="请输入姓名" />
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-2">公司名称</label>
          <input type="text" name="company" class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder-gray-600 focus:border-brand-gold focus:outline-none" placeholder="请输入公司名称" />
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-2">联系电话 *</label>
          <input type="tel" name="phone" required class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder-gray-600 focus:border-brand-gold focus:outline-none" placeholder="请输入电话" />
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-2">邮箱</label>
          <input type="email" name="email" class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder-gray-600 focus:border-brand-gold focus:outline-none" placeholder="请输入邮箱" />
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-2">您的需求 *</label>
          <textarea name="message" required rows="5" class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder-gray-600 focus:border-brand-gold focus:outline-none resize-none" placeholder="请描述您的项目需求..."></textarea>
        </div>
        <button type="submit" class="btn btn-gold w-full py-4 text-lg">提交需求</button>
      </form>
    </div>
  </section>
</BaseLayout>
