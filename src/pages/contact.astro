---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getFileContent } from '../core/content';
const general = getFileContent('src/content/settings/general.yml') || {};
---
<BaseLayout title="留言">
  <section style="padding:60px 0">
    <div style="max-width:600px;margin:0 auto;padding:0 40px">
      <h1 style="font-size:34px;font-weight:400;color:var(--xt-primary);margin-bottom:0.3em">给我<span style="font-weight:300">留言</span></h1>
      <p style="font-size:16px;color:var(--xt-muted);margin-bottom:40px">有任何问题或建议，欢迎留言</p>
      <form method="POST" action="/api/contact" style="display:grid;gap:20px">
        <input name="name" placeholder="姓名 *" required style="padding:12px 16px;border:1px solid #ddd;font-size:16px;width:100%;border-radius:4px" />
        <input name="company" placeholder="公司" style="padding:12px 16px;border:1px solid #ddd;font-size:16px;width:100%;border-radius:4px" />
        <input name="phone" placeholder="电话 *" required style="padding:12px 16px;border:1px solid #ddd;font-size:16px;width:100%;border-radius:4px" />
        <input name="email" placeholder="邮箱" type="email" style="padding:12px 16px;border:1px solid #ddd;font-size:16px;width:100%;border-radius:4px" />
        <textarea name="message" placeholder="留言内容" rows="5" style="padding:12px 16px;border:1px solid #ddd;font-size:16px;width:100%;resize:vertical;border-radius:4px"></textarea>
        <button type="submit" style="padding:12px 32px;background:#000;color:#fff;border:none;font-size:16px;cursor:pointer;border-radius:4px;justify-self:start">发送</button>
      </form>
    </div>
  </section>
</BaseLayout>
