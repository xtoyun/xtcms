---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const featuredProjects = (await getCollection('projects'))
  .filter(p => p.data.featured)
  .slice(0, 3);
---

<BaseLayout>
  <!-- ===== Hero - centered text, no image ===== -->
  <section class="py-20 md:py-32 text-center">
    <div class="container-main">
      <h1 style="font-size:50px;font-weight:400;line-height:1.2;color:#000">
        打造网络品牌
        <span id="rotating-text" style="display:inline-block;vertical-align:bottom;overflow:hidden;height:60px;width:250px;position:relative">
          <span id="rotating-inner" style="position:absolute;left:0;top:0;width:100%;transition:transform 0.5s cubic-bezier(0.4,0,0.2,1)">
            <span class="rotate-line" style="display:block;height:60px;line-height:60px">自媒体品牌</span>
            <span class="rotate-line" style="display:block;height:60px;line-height:60px">互联网营销</span>
          </span>
        </span>
      </h1>
      <p style="font-size:22px;font-weight:300;color:#7C7F83;margin-top:0.3em;margin-bottom:0.2em">把生意服务到全世界</p>
      <p style="font-size:18px;font-weight:400;color:#000;letter-spacing:3px">网络营销品牌</p>
    </div>
  </section>

  <script is:inline>
    (function(){
      const inner = document.getElementById('rotating-inner');
      if(!inner) return;
      const items = inner.querySelectorAll('.rotate-line');
      const total = items.length;
      let current = 0;
      const h = 60;
      setInterval(()=>{
        current = (current+1)%total;
        inner.style.transform = 'translateY(-'+ (current*h) +'px)';
      }, 2500);
    })();
  </script>

  <!-- ===== Section 3: 关于 - image left, text right ===== -->
  <section style="padding:80px 0;display:flex;align-items:center;min-height:60vh">
    <div style="flex:1;padding-right:40px">
      <img src="/art-home-05.jpeg" alt="雄韬网络" style="width:100%;height:auto;display:block" />
    </div>
    <div style="flex:1;padding-left:20px">
      <h2 style="font-size:34px;font-weight:400;color:#000;margin-bottom:0.8em">Hello! 我们是雄韬网络.</h2>
      <p style="font-size:18px;font-weight:300;color:#7C7F83;line-height:1.8;margin-bottom:2em">
        15年互联网营销品牌，用最新的技术和趋势，为您的企业提供现代设计与开发，把生意服务到全世界。
      </p>
      <div class="flex gap-4 mb-10">
        <a href="/posts" class="btn-the7">案例</a>
        <a href="/about" class="btn-the7">关于</a>
      </div>
      <div class="flex gap-12">
        <div><div style="font-size:44px;font-weight:400;color:#000;line-height:1.7">15<span style="font-size:24px">+</span></div><div style="font-size:14px;color:#7C7F83">年行业经验</div></div>
        <div><div style="font-size:44px;font-weight:400;color:#000;line-height:1.7">500<span style="font-size:24px">+</span></div><div style="font-size:14px;color:#7C7F83">服务企业</div></div>
      </div>
    </div>
  </section>

  <!-- ===== Section 4: 项目作品集 - 3 column grid ===== -->
  <section class="py-16">
    <div class="container-main">
      <h2 class="text-center" style="font-size:34px;font-weight:400;color:#000;margin-bottom:0.3em">精选<span style="font-weight:300">案例</span></h2>
      <p class="text-center" style="color:#7C7F83;margin-bottom:3em">为您的企业提供数字解决方案</p>

      {
        featuredProjects.length > 0 ? (
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {featuredProjects.map(project => (
              <a href={`/projects/${project.id}`} class="group block no-underline">
                <div class="aspect-[4/3] bg-gray-100 flex items-center justify-center overflow-hidden mb-4">
                  {project.data.image ? (
                    <img src={project.data.image} alt={project.data.title} class="w-full h-full object-cover" />
                  ) : (
                    <span class="text-sm text-gray-400">{project.data.title}</span>
                  )}
                </div>
                <span style="font-size:13px;color:#7C7F83">{project.data.category}</span>
                <h5 class="mt-1 group-hover:opacity-70 transition-opacity" style="color:#000">{project.data.title}</h5>
              </a>
            ))}
          </div>
        ) : (
          <div class="text-center py-12" style="color:#7C7F83">项目案例即将上线</div>
        )
      }
    </div>
  </section>

  <!-- ===== Section 5: 数字解决方案 CTA - left/right split ===== -->
  <section class="py-16">
    <div class="container-main">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 style="font-size:34px;font-weight:400;color:#000;margin-bottom:0.5em">为您的企业提供数字<span style="font-weight:300">解决方案</span></h2>
          <p style="font-size:18px;font-weight:300;color:#7C7F83;line-height:1.8;margin-bottom:2em">把生意服务到全世界</p>
          <a href="/contact" class="btn-the7 btn-the7-lg">联系我们</a>
        </div>
        <div>
          <ol style="list-style:decimal;padding-left:1.5em;font-size:16px;color:#7C7F83;line-height:2.5">
            <li>网络广告</li>
            <li>搜索引擎优化(SEO)</li>
            <li>社交媒体营销</li>
            <li>内容营销</li>
            <li>数据分析和营销策略</li>
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Section 6: 服务图标卡片 - 6 column grid ===== -->
  <section class="py-16">
    <div class="container-main">
      <h2 class="text-center" style="font-size:34px;font-weight:400;color:#000;margin-bottom:2em">我们擅长<span style="font-weight:300">什么</span>？</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6 text-center">
        <div class="p-4"><div class="text-2xl mb-2">🌐</div><div style="font-size:14px;font-weight:600;color:#000">营销型网站建设</div></div>
        <div class="p-4"><div class="text-2xl mb-2">📊</div><div style="font-size:14px;font-weight:600;color:#000">数字化营销</div></div>
        <div class="p-4"><div class="text-2xl mb-2">🎯</div><div style="font-size:14px;font-weight:600;color:#000">网络品牌</div></div>
        <div class="p-4"><div class="text-2xl mb-2">📈</div><div style="font-size:14px;font-weight:600;color:#000">网络优化</div></div>
        <div class="p-4"><div class="text-2xl mb-2">📝</div><div style="font-size:14px;font-weight:600;color:#000">内容营销</div></div>
        <div class="p-4"><div class="text-2xl mb-2">📋</div><div style="font-size:14px;font-weight:600;color:#000">数据分析</div></div>
      </div>
    </div>
  </section>

  <!-- ===== Section 7: CTA - centered ===== -->
  <section class="py-16 text-center">
    <div class="container-main max-w-xl">
      <h2 style="font-size:34px;font-weight:400;color:#000;margin-bottom:0.5em">请告诉您的<span style="font-weight:300">需求</span>！</h2>
      <p style="font-size:18px;font-weight:300;color:#7C7F83;margin-bottom:2em">我们为你提供更好服务</p>
      <a href="/contact" class="btn-the7 btn-the7-lg">马上联系</a>
    </div>
  </section>
</BaseLayout>
