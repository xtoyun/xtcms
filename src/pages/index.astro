---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getContent, getFileContent } from '../core/content';

const homepage = getFileContent('src/content/settings/homepage.yml') || {};
const featuredProjects = getContent('projects', 'src/content/projects')
  .filter(p => p.data.featured)
  .slice(0, homepage.projects_count || 3);
const services = getContent('services', 'src/content/services')
  .sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
const opensourceProjects = getContent('opensource', 'src/content/opensource');
const latestPosts = getContent('posts', 'src/content/posts')
  .filter(p => !p.data.draft)
  .slice(0, 3);
---

<BaseLayout>
  <!-- Hero -->
  <section style="padding:100px 0 80px;text-align:center;background:url(/art-top00.png) center/cover no-repeat;min-height:400px;display:flex;align-items:center;justify-content:center">
    <div class="container">
      <h1 style="font-size:50px;font-weight:400;line-height:1.2;color:#000">
        {homepage.hero_title || '打造网络品牌'}
      </h1>
      <p style="font-size:22px;font-weight:300;color:var(--xt-muted);margin-top:0.3em;margin-bottom:0.2em">
        {homepage.hero_subtitle || '把生意服务到全世界'}
      </p>
      <p style="font-size:18px;font-weight:400;color:#000;letter-spacing:3px">
        {homepage.hero_tagline || '网络营销品牌'}
      </p>
    </div>
  </section>

  <!-- About -->
  <section style="padding:60px 0;display:flex;align-items:center;gap:40px" class="container">
    <div style="flex:1"><img src="/art-home-05.jpeg" alt="" style="width:100%;height:auto" /></div>
    <div style="flex:1">
      <h2 style="font-size:28px;font-weight:400;color:#000;margin-bottom:0.6em">
        {homepage.about_title || 'Hello! 我们是雄韬网络.'}
      </h2>
      <p style="font-size:16px;font-weight:300;color:var(--xt-muted);line-height:1.8;margin-bottom:1.5em">
        {homepage.about_desc || '15年互联网营销品牌，用最新的技术和趋势，为您的企业提供现代设计与开发。'}
      </p>
      <div class="flex" style="display:flex;gap:12px;margin-bottom:30px">
        <a href="/projects" class="btn btn-outline">案例</a>
        <a href="/about" class="btn btn-outline">关于</a>
      </div>
      <div style="display:flex;gap:40px">
        <div><div style="font-size:36px;font-weight:400;color:#000;line-height:1.4">15<span style="font-size:20px">+</span></div><div style="font-size:13px;color:var(--xt-muted)">年行业经验</div></div>
        <div><div style="font-size:36px;font-weight:400;color:#000;line-height:1.4">500<span style="font-size:20px">+</span></div><div style="font-size:13px;color:var(--xt-muted)">服务企业</div></div>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <section style="padding:60px 0">
    <div class="container">
      <h2 class="text-center" style="font-size:34px;font-weight:400;color:#000;margin-bottom:0.3em;text-align:center">
        精选<span style="font-weight:300">案例</span>
      </h2>
      <p style="text-align:center;color:var(--xt-muted);margin-bottom:3em">为您的企业提供数字解决方案</p>
      {featuredProjects.length > 0 ? (
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:24px">
          {featuredProjects.map(p => (
            <a href={`/projects/${p.slug}`} style="text-decoration:none;color:inherit;display:block">
              <div style="aspect-ratio:4/3;background:#f5f5f5;overflow:hidden;margin-bottom:16px">
                {p.data.image ? <img src={p.data.image} alt={p.data.title} style="width:100%;height:100%;object-fit:cover" /> : <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#ccc;font-size:48px">📁</div>}
              </div>
              <span style="font-size:13px;color:var(--xt-muted)">{p.data.category}</span>
              <h5 style="margin-top:4px;color:#000;font-size:16px;font-weight:500">{p.data.title}</h5>
            </a>
          ))}
        </div>
      ) : (
        <p style="text-align:center;color:var(--xt-muted);padding:40px">项目案例即将上线</p>
      )}
    </div>
  </section>

  <!-- Services -->
  <section style="padding:60px 0">
    <div class="container">
      <h2 style="font-size:34px;font-weight:400;color:#000;margin-bottom:2em;text-align:center">
        我们擅长<span style="font-weight:300">什么</span>？
      </h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:24px;text-align:center">
        {services.map(s => (
          <a href={`/services/${s.slug}`} style="text-decoration:none;color:inherit;display:block;padding:16px 8px;opacity:0.75;transition:opacity 0.2s">
            <div style="font-size:36px;margin-bottom:12px">{s.data.icon || '📌'}</div>
            <div style="font-size:14px;font-weight:600;color:#000">{s.data.title}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Open Source -->
  {opensourceProjects.length > 0 && (
    <section style="padding:60px 0;background:#fafafa">
      <div class="container">
        <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:40px">
          <div>
            <h2 style="font-size:34px;font-weight:400;color:#000;margin-bottom:0.2em">开源<span style="font-weight:300">项目</span></h2>
            <p style="font-size:15px;color:var(--xt-muted)">Apache-2.0 许可 · 社区驱动 · 自由开放</p>
          </div>
          <a href="/open" style="font-size:14px;color:var(--xt-muted);text-decoration:none;display:flex;align-items:center;gap:4px">查看全部 →</a>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:24px">
          {opensourceProjects.map(p => (
            <a href={p.data.link || `/open/${p.slug}`} target={p.data.link ? '_blank' : '_self'} rel={p.data.link ? 'noopener' : ''} style="text-decoration:none;color:inherit;display:block;background:#fff;border:1px solid #eee;overflow:hidden;transition:border-color 0.2s">
              <div style="aspect-ratio:360/250;background:#f5f5f5;overflow:hidden">
                {p.data.image ? <img src={p.data.image} alt={p.data.title} style="width:100%;height:100%;object-fit:cover" /> : <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#ccc;font-size:48px">📦</div>}
              </div>
              <div style="padding:24px">
                <div style="display:flex;align-items:baseline;gap:8px;margin-bottom:8px">
                  <h3 style="font-size:18px;font-weight:500;color:#000">{p.data.title}</h3>
                  <span style="font-size:11px;color:#999">{p.data.tag}</span>
                </div>
                <p style="font-size:13px;color:#888;line-height:1.7">{p.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Latest Posts -->
  {latestPosts.length > 0 && (
    <section style="padding:60px 0;background:#fafafa">
      <div class="container">
        <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:40px">
          <h2 style="font-size:34px;font-weight:400;color:#000">最新<span style="font-weight:300">文章</span></h2>
          <a href="/posts" style="font-size:14px;color:var(--xt-muted)">查看全部 →</a>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:24px">
          {latestPosts.map(p => (
            <a href={p.data.link || `/posts/${p.slug}`} style="text-decoration:none;color:inherit;display:block;background:#fff;border:1px solid #eee;overflow:hidden">
              {p.data.image && <img src={p.data.image} alt={p.data.title} style="width:100%;aspect-ratio:16/9;object-fit:cover" />}
              <div style="padding:24px">
                <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
                  <time style="font-size:12px;color:#aaa">{p.data.date ? new Date(p.data.date).toLocaleDateString('zh-CN') : ''}</time>
                </div>
                <h3 style="font-size:17px;font-weight:500;color:#000;line-height:1.5;margin-bottom:8px">{p.data.title}</h3>
                {p.data.description && <p style="font-size:13px;color:#999;line-height:1.6;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical">{p.data.description}</p>}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section style="padding:60px 0;text-align:center">
    <div class="container" style="max-width:600px">
      <h2 style="font-size:34px;font-weight:400;color:#000;margin-bottom:0.5em">请告诉您的<span style="font-weight:300">需求</span>！</h2>
      <p style="font-size:18px;font-weight:300;color:var(--xt-muted);margin-bottom:2em">我们为你提供更好服务</p>
      <a href="/contact" class="btn btn-lg">马上联系</a>
    </div>
  </section>
</BaseLayout>
