<script is:inline>
  (function() {
    var btn = document.getElementById('fc-wechat');
    var modal = document.getElementById('wechat-modal');
    if (!btn || !modal) return;
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      modal.classList.add('show');
    });
  })();
</script>

<style is:global>
  /* Floating bar */
  .fc-bar {
    position: fixed;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 998;
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: #fff;
    border-radius: 8px;
    box-shadow: 0 2px 16px rgba(0,0,0,.08);
    overflow: hidden;
  }

  .fc-item {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    color: #555;
    text-decoration: none;
    position: relative;
    transition: background .2s, color .2s;
    cursor: pointer;
    background: #fff;
    border: none;
    font-family: inherit;
    padding: 0;
  }

  .fc-item:hover {
    background: #1a1a1a;
    color: #fff;
  }

  .fc-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .fc-tip {
    position: absolute;
    right: 60px;
    top: 50%;
    transform: translateY(-50%);
    background: #1a1a1a;
    color: #fff;
    padding: 8px 14px;
    border-radius: 6px;
    font-size: 13px;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transition: opacity .2s, visibility .2s;
  }

  .fc-tip::after {
    content: '';
    position: absolute;
    right: -5px;
    top: 50%;
    transform: translateY(-50%);
    border: 5px solid transparent;
    border-left-color: #1a1a1a;
    border-right: none;
  }

  .fc-item:hover .fc-tip {
    opacity: 1;
    visibility: visible;
  }

  @media (max-width: 768px) {
    .fc-bar {
      right: 8px;
    }
    .fc-item {
      width: 40px;
      height: 40px;
    }
    .fc-tip {
      display: none;
    }
  }

  /* WeChat modal overlay */
  .wechat-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0,0,0,.5);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity .3s, visibility .3s;
  }

  .wechat-overlay.show {
    opacity: 1;
    visibility: visible;
  }

  .wechat-card {
    background: #fff;
    border-radius: 16px;
    padding: 40px 44px 32px;
    text-align: center;
    max-width: 360px;
    width: 90%;
    position: relative;
    box-shadow: 0 20px 60px rgba(0,0,0,.2);
    animation: wechatIn .35s ease;
  }

  @keyframes wechatIn {
    from { transform: translateY(20px) scale(.95); opacity: 0; }
    to   { transform: translateY(0) scale(1); opacity: 1; }
  }

  .wechat-close {
    position: absolute;
    top: 12px;
    right: 16px;
    background: none;
    border: none;
    font-size: 28px;
    color: #aaa;
    cursor: pointer;
    line-height: 1;
    padding: 4px;
    transition: color .2s;
  }

  .wechat-close:hover { color: #333; }

  .wechat-card-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto 16px;
    border-radius: 50%;
    background: #f0fdf4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .wechat-card h3 {
    margin: 0 0 6px;
    font-size: 20px;
    font-weight: 500;
    color: #1a1a1a;
  }

  .wechat-sub {
    margin: 0 0 24px;
    font-size: 14px;
    color: #999;
  }

  .wechat-qr-wrap {
    display: inline-block;
    padding: 12px;
    border: 2px solid #07c160;
    border-radius: 12px;
    margin-bottom: 16px;
    line-height: 0;
  }

  .wechat-qr-wrap img {
    display: block;
    border-radius: 8px;
  }

  .wechat-id {
    margin: 0;
    font-size: 14px;
    color: #666;
    letter-spacing: .5px;
  }
</style>
