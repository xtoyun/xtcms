---
export interface Props {
  src?: string | null;
  alt?: string;
  aspect?: string;
  label?: string;
  class?: string;
}

const { src, alt = '', aspect = '16/9', label = '雄韬 XTOCN', class: className = '' } = Astro.props;

// Filter out empty strings and obvious invalid values
const hasSrc = src && src.trim().length > 0;
---

<div style="aspect-ratio: {aspect}; overflow: hidden; position: relative; {className}">
  {hasSrc ? (
    <>
      <img
        src={src}
        alt={alt}
        style="width:100%;height:100%;object-fit:cover;display:block"
        onerror={`this.style.display='none';this.nextElementSibling.style.display='flex';`}
      />
      <div style="display:none; width:100%; height:100%; background: linear-gradient(135deg, #e8e8e8 0%, #f0f0f0 30%, #eaeaea 60%, #f5f5f5 100%); align-items: center; justify-content: center; overflow: hidden; position: relative;">
        <div style="position: absolute; top: -30%; right: -10%; width: 60%; height: 100%; border-radius: 50%; background: linear-gradient(180deg, rgba(0,0,0,.02) 0%, transparent 70%); pointer-events: none;"></div>
        <div style="position: absolute; bottom: -20%; left: -5%; width: 40%; height: 70%; border-radius: 50%; background: linear-gradient(0deg, rgba(0,0,0,.015) 0%, transparent 60%); pointer-events: none;"></div>
        <div style="text-align: center; z-index: 1; padding: 20px;">
          <div style="width: 48px; height: 48px; margin: 0 auto 12px; border-radius: 50%; background: rgba(0,0,0,.06); display: flex; align-items: center; justify-content: center;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgba(0,0,0,.2)" stroke-width="1.5">
              <rect x="3" y="3" width="18" height="18" rx="3"/>
              <circle cx="8.5" cy="8.5" r="1.5" fill="rgba(0,0,0,.15)" stroke="none"/>
              <circle cx="15.5" cy="8.5" r="1.5" fill="rgba(0,0,0,.15)" stroke="none"/>
              <path d="M6 15c2-2 4-3 6-1s4-2 6 1" stroke="rgba(0,0,0,.15)" stroke-width="1.5" fill="none"/>
              <line x1="12" y1="17" x2="12" y2="21" stroke="rgba(0,0,0,.12)" stroke-width="1.5"/>
              <line x1="9" y1="21" x2="15" y2="21" stroke="rgba(0,0,0,.12)" stroke-width="1.5"/>
            </svg>
          </div>
          <div style="font-size: 13px; font-weight: 400; color: rgba(0,0,0,.25); letter-spacing: 3px;">
            {label}
          </div>
        </div>
      </div>
    </>
  ) : (
    <div style="width:100%;height:100%;background: linear-gradient(135deg, #e8e8e8 0%, #f0f0f0 30%, #eaeaea 60%, #f5f5f5 100%); display: flex; align-items: center; justify-content: center; overflow: hidden; position: relative;">
      <div style="position: absolute; top: -30%; right: -10%; width: 60%; height: 100%; border-radius: 50%; background: linear-gradient(180deg, rgba(0,0,0,.02) 0%, transparent 70%); pointer-events: none;"></div>
      <div style="position: absolute; bottom: -20%; left: -5%; width: 40%; height: 70%; border-radius: 50%; background: linear-gradient(0deg, rgba(0,0,0,.015) 0%, transparent 60%); pointer-events: none;"></div>
      <div style="text-align: center; z-index: 1; padding: 20px;">
        <div style="width: 48px; height: 48px; margin: 0 auto 12px; border-radius: 50%; background: rgba(0,0,0,.06); display: flex; align-items: center; justify-content: center;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgba(0,0,0,.2)" stroke-width="1.5">
            <rect x="3" y="3" width="18" height="18" rx="3"/>
            <circle cx="8.5" cy="8.5" r="1.5" fill="rgba(0,0,0,.15)" stroke="none"/>
            <circle cx="15.5" cy="8.5" r="1.5" fill="rgba(0,0,0,.15)" stroke="none"/>
            <path d="M6 15c2-2 4-3 6-1s4-2 6 1" stroke="rgba(0,0,0,.15)" stroke-width="1.5" fill="none"/>
            <line x1="12" y1="17" x2="12" y2="21" stroke="rgba(0,0,0,.12)" stroke-width="1.5"/>
            <line x1="9" y1="21" x2="15" y2="21" stroke="rgba(0,0,0,.12)" stroke-width="1.5"/>
          </svg>
        </div>
        <div style="font-size: 13px; font-weight: 400; color: rgba(0,0,0,.25); letter-spacing: 3px;">
          {label}
        </div>
      </div>
    </div>
  )}
</div>
