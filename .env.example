# CMS 认证配置（生产环境必填）
CMS_USER=admin
CMS_PASS=admin
CMS_SECRET=your-random-secret-here

# 外部 API Key（用于 OpenClaw Skill 等外部接入提交文章）
CMS_API_KEY=xtocn-api-key-change-me

# 部署端口（可选）
# PORT=4321
# HOST=0.0.0.0

# CMS 后台文章列表每页条数（默认 50，上限 200）
# CMS_PAGE_SIZE=50

# Git 自动提交（默认关闭，手动 git commit）
# CMS_AUTO_COMMIT=true
# CMS_AUTO_PUSH=true
